# Окружение: development | production
NODE_ENV="development"

# URL приложения (используется для CORS и ссылок)
APP_URL="http://localhost:3000"

# Секрет для подписи JWT-токенов — замените на длинную случайную строку в production
JWT_SECRET="замените-на-случайную-строку-не-менее-32-символов"

# Путь к базе данных Prisma (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Опционально: ключ Gemini AI для раздела "Аналитика → Прогноз спроса"
# Без него все функции ERP работают, кроме AI-прогнозирования
# GEMINI_API_KEY="ваш-ключ-от-aistudio.google.com"
